# Visit Big Spring — environment variables
# Copy this file to .env.local and fill in real values.

# Public Mapbox token (starts with pk.). Free tier covers 50k map loads/month.
# Get one at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Set to "true" to expose /demo-admin on the deployed URL. Evaluators only.
# Leave unset in production.
SHOW_DEMO_ADMIN=
